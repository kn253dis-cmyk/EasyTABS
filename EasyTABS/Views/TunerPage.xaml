<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyTABS.ViewModels"
             xmlns:drawables="clr-namespace:EasyTABS.Views"
             x:Class="EasyTABS.Views.TunerPage"
             x:DataType="vm:TunerViewModel"
             Title="Хроматичний тюнер"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:TunerViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <drawables:TunerDrawable x:Key="TunerDrawable" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20" RowSpacing="12">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#1E1E24" Offset="0" />
                <GradientStop Color="#121212" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Перемикач режиму -->
        <Border Grid.Row="0"
                BackgroundColor="#202124"
                Stroke="#33FFFFFF"
                StrokeThickness="1"
                Padding="16,8"
                HorizontalOptions="Center"
                Margin="0,6,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <HorizontalStackLayout Spacing="12">
                <Label Text="Тюнер"
                       FontSize="14"
                       TextColor="#B0B0B0"
                       VerticalOptions="Center" />
                <Switch IsToggled="{Binding IsChordMode}"
                        OnColor="#8A2BE2"
                        ThumbColor="White"
                        VerticalOptions="Center" />
                <Label Text="Акорди"
                       FontSize="14"
                       TextColor="#B0B0B0"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <!-- Компактний рядок: нота / акорд + частота (менший шрифт) -->
        <HorizontalStackLayout Grid.Row="1"
                               HorizontalOptions="Center"
                               Spacing="14">
            <Label Text="{Binding NoteText}"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="{Binding IsLocked, Converter={StaticResource BoolToNoteColorConverter}}"
                   VerticalOptions="Center" />
            <Label Text="{Binding ChordText}"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#8A2BE2"
                   IsVisible="{Binding IsChordMode}"
                   VerticalOptions="Center" />
            <Label Text="{Binding FrequencyText}"
                   FontSize="16"
                   TextColor="#B0B0B0"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Великий графік -->
        <Border Grid.Row="2"
                BackgroundColor="#0A0A0A"
                Stroke="#33FFFFFF"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>
            <GraphicsView x:Name="GraphView"
                          Drawable="{StaticResource TunerDrawable}" />
        </Border>

        <!-- Кнопки керування -->
        <HorizontalStackLayout Grid.Row="3"
                               HorizontalOptions="Center"
                               Spacing="20"
                               Margin="0,0,0,10">
            <Button Text="Слухати"
                    Command="{Binding StartCommand}"
                    WidthRequest="140"
                    HeightRequest="48"
                    BackgroundColor="LimeGreen"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10" />

            <Button Text="Зупинити"
                    Command="{Binding StopCommand}"
                    WidthRequest="140"
                    HeightRequest="48"
                    BackgroundColor="Crimson"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
