<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyTABS.ViewModels"
             xmlns:drawables="clr-namespace:EasyTABS.Views"
             x:Class="EasyTABS.Views.TunerPage"
             x:DataType="vm:TunerViewModel"
             Title="Хроматичний тюнер"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:TunerViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <drawables:SpectrumDrawable x:Key="SpectrumDrawable" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#1E1E24" Offset="0" />
                <GradientStop Color="#121212" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Нота та частота -->
        <Border Grid.Row="0"
                BackgroundColor="#202124"
                Stroke="#33FFFFFF"
                StrokeThickness="1"
                Padding="40,15"
                HorizontalOptions="Center"
                Margin="0,10,0,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>
            <VerticalStackLayout>
                <Label Text="{Binding NoteText}"
                       FontSize="48"
                       FontAttributes="Bold"
                       TextColor="{Binding IsListening, Converter={StaticResource BoolToNoteColorConverter}}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
                <Label Text="{Binding FrequencyText}"
                       FontSize="22"
                       TextColor="#B0B0B0"
                       HorizontalOptions="Center"
                       Margin="0,5,0,0" />
            </VerticalStackLayout>
        </Border>

        <!-- Спектр -->
        <Border Grid.Row="1"
                BackgroundColor="#0A0A0A"
                Stroke="#33FFFFFF"
                StrokeThickness="1"
                Margin="0,0,0,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>
            <GraphicsView Drawable="{StaticResource SpectrumDrawable}" />
        </Border>

        <!-- Кнопки керування -->
        <HorizontalStackLayout Grid.Row="2"
                               HorizontalOptions="Center"
                               Spacing="20"
                               Margin="0,0,0,20">
            <Button Text="Слухати"
                    Command="{Binding StartCommand}"
                    WidthRequest="140"
                    HeightRequest="48"
                    BackgroundColor="LimeGreen"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10" />

            <Button Text="Зупинити"
                    Command="{Binding StopCommand}"
                    WidthRequest="140"
                    HeightRequest="48"
                    BackgroundColor="Crimson"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
