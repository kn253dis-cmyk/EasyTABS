<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyTABS.ViewModels"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:svc="clr-namespace:EasyTABS.Services"
             x:Class="EasyTABS.Views.AddSongPage"
             x:Name="AddSongRoot"
             x:DataType="vm:AddSongViewModel"
             Title="Додати пісню"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:AddSongViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#1E1E24" Offset="0" />
                <GradientStop Color="#121212" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <Border Stroke="Transparent"
                    BackgroundColor="#202124"
                    Padding="32"
                    Margin="24"
                    VerticalOptions="Center"
                    MaximumWidthRequest="650"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="12" Margin="0,0,0,28">
                        <mi:MauiIcon Icon="{mi:Material LibraryMusic}" IconSize="32" IconColor="#8A2BE2" VerticalOptions="Center" />
                        <Label Text="Додайте свою пісню"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Grid Margin="0,0,0,20">
                        <Border Style="{StaticResource FieldBorder}">
                            <Grid ColumnDefinitions="Auto, *">
                                <mi:MauiIcon Grid.Column="0" Icon="{mi:Material MusicNote}" IconColor="#808080" IconSize="22" Margin="15,0,0,0" VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Margin="10,0,15,0"
                                       Placeholder="Назва пісні"
                                       Text="{Binding SongName}"
                                       TextColor="White"
                                       PlaceholderColor="#808080"
                                       BackgroundColor="Transparent"
                                       FontSize="16" />
                            </Grid>
                        </Border>

                        <Border BackgroundColor="#2A2D34" Stroke="#404040" Padding="0" Margin="0,54,0,0"
                                VerticalOptions="Start" ZIndex="10" MaximumHeightRequest="220"
                                IsVisible="{Binding IsSongSuggestionsVisible}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <CollectionView ItemsSource="{Binding SongSuggestions}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid Padding="12,10" BackgroundColor="Transparent">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={x:Reference AddSongRoot}, Path=BindingContext.SelectSongSuggestionCommand}" CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>
                                            <Label Text="{Binding .}" FontSize="15" TextColor="White" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,20">
                        <Border Style="{StaticResource FieldBorder}">
                            <Grid ColumnDefinitions="Auto, *">
                                <mi:MauiIcon Grid.Column="0" Icon="{mi:Material Person}" IconColor="#808080" IconSize="22" Margin="15,0,0,0" VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Margin="10,0,15,0"
                                       Placeholder="Виконавець"
                                       Text="{Binding Artist}"
                                       TextColor="White"
                                       PlaceholderColor="#808080"
                                       BackgroundColor="Transparent"
                                       FontSize="16" />
                            </Grid>
                        </Border>

                        <Border BackgroundColor="#2A2D34" Stroke="#404040" Padding="0" Margin="0,54,0,0"
                                VerticalOptions="Start" ZIndex="10" MaximumHeightRequest="220"
                                IsVisible="{Binding IsArtistSuggestionsVisible}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <CollectionView ItemsSource="{Binding ArtistSuggestions}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid Padding="12,10" BackgroundColor="Transparent">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={x:Reference AddSongRoot}, Path=BindingContext.SelectArtistSuggestionCommand}" CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>
                                            <Label Text="{Binding .}" FontSize="15" TextColor="White" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,20">
                        <Border Style="{StaticResource FieldBorder}">
                            <Grid ColumnDefinitions="Auto, *">
                                <mi:MauiIcon Grid.Column="0" Icon="{mi:Material Album}" IconColor="#808080" IconSize="22" Margin="15,0,0,0" VerticalOptions="Center" />
                                <Entry Grid.Column="1"
                                       Margin="10,0,15,0"
                                       Placeholder="Альбом"
                                       Text="{Binding Album}"
                                       TextColor="White"
                                       PlaceholderColor="#808080"
                                       BackgroundColor="Transparent"
                                       FontSize="16" />
                            </Grid>
                        </Border>

                        <!-- Попап альбомів з прев'ю обкладинки -->
                        <Border BackgroundColor="#2A2D34" Stroke="#404040" Padding="0" Margin="0,54,0,0"
                                VerticalOptions="Start" ZIndex="10" MaximumHeightRequest="260"
                                IsVisible="{Binding IsAlbumSuggestionsVisible}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <CollectionView ItemsSource="{Binding AlbumSuggestions}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="svc:AlbumSuggestion">
                                        <Grid Padding="10,8" ColumnDefinitions="Auto,*" ColumnSpacing="12" BackgroundColor="Transparent">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={x:Reference AddSongRoot}, Path=BindingContext.SelectAlbumSuggestionCommand}" CommandParameter="{Binding .}" />
                                            </Grid.GestureRecognizers>

                                            <Border Grid.Column="0" WidthRequest="42" HeightRequest="42" Stroke="Transparent">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="6" />
                                                </Border.StrokeShape>
                                                <Image Source="{Binding CoverData, Converter={StaticResource BytesToImageConverter}}"
                                                       Aspect="AspectFill" />
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                <Label Text="{Binding Title}" FontSize="15" FontAttributes="Bold" TextColor="White" />
                                                <Label Text="{Binding ArtistName}" FontSize="12" TextColor="#808080" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                    </Grid>

                    <!-- Статус: звідки взято обкладинку -->
                    <Label Text="{Binding CoverStatusText}"
                           TextColor="#8A2BE2"
                           FontSize="12"
                           IsVisible="{Binding CoverStatusText, Converter={StaticResource StringNotEmptyConverter}}"
                           Margin="4,0,0,12" />

                    <Border BackgroundColor="#18191C"
                            Stroke="#8A2BE2"
                            StrokeThickness="2"
                            HeightRequest="180"
                            Margin="0,10,0,28">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PickFileCommand}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">

                            <mi:MauiIcon Icon="{mi:Material UploadFile}"
                                         IconSize="50"
                                         IconColor="#8A2BE2"
                                         HorizontalOptions="Center"
                                         IsVisible="{Binding IsFileSelected, Converter={StaticResource InverseBoolConverter}}"
                                         Margin="0,0,0,10" />

                            <mi:MauiIcon Icon="{mi:Material CheckCircle}"
                                         IconSize="60"
                                         IconColor="LimeGreen"
                                         HorizontalOptions="Center"
                                         IsVisible="{Binding IsFileSelected}"
                                         Margin="0,0,0,10" />

                            <Label Text="{Binding FileStatusText}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#E0E0E0"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />

                            <Label Text="Підтримуються файли Guitar Pro"
                                   FontSize="13"
                                   TextColor="#808080"
                                   HorizontalOptions="Center"
                                   Margin="0,5,0,0" />
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="#333333" HeightRequest="48" Stroke="Transparent" Margin="0,0,0,20">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PickCoverCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                            <mi:MauiIcon Icon="{mi:Material Image}" IconColor="White" IconSize="20" />
                            <Label Text="Обрати обкладинку (необов'язково)" TextColor="White" FontSize="14" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#FF6B6B"
                           FontSize="13"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                           Margin="0,0,0,12" />

                    <Border BackgroundColor="#8A2BE2" HeightRequest="55" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AddCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                            <mi:MauiIcon Icon="{mi:Material AddCircleOutline}" IconColor="White" IconSize="24" />
                            <Label Text="Додати в бібліотеку" TextColor="White" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>
