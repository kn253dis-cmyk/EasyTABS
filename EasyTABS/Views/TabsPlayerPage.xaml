<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyTABS.ViewModels"
             xmlns:svc="clr-namespace:EasyTABS.Services"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="EasyTABS.Views.TabsPlayerPage"
             x:Name="PlayerRoot"
             x:DataType="vm:TabsPlayerViewModel"
             Title="{Binding Title}"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:TabsPlayerViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#1E1E24" Offset="0" />
                <GradientStop Color="#121212" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Шапка: обкладинка + назва + кнопка доріжок -->
        <Border Grid.Row="0"
                BackgroundColor="#202124"
                Stroke="Transparent"
                Padding="16"
                Margin="10,10,10,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Border Grid.Column="0"
                        WidthRequest="56" HeightRequest="56"
                        Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Image Source="{Binding AlbumCoverData, Converter={StaticResource BytesToImageConverter}}"
                           Aspect="AspectFill" />
                </Border>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" TextColor="White" />
                    <Label Text="{Binding ArtistName}" FontSize="13" TextColor="#B0B0B0" />
                </VerticalStackLayout>

                <!-- Кнопка "Доріжки" з лічильником -->
                <Border Grid.Column="2"
                        BackgroundColor="#2A2D34"
                        Stroke="#404040"
                        StrokeThickness="1"
                        Padding="14,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleTrackListCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <mi:MauiIcon Icon="{mi:Material QueueMusic}" IconColor="#8A2BE2" IconSize="22" VerticalOptions="Center" />
                        <Label Text="{Binding TracksSummary}" TextColor="White" FontSize="14" VerticalOptions="Center" />
                        <mi:MauiIcon Icon="{mi:Material ExpandMore}" IconColor="#808080" IconSize="20" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Border>

        <!-- Панель списку доріжок (розкривна) -->
        <Border Grid.Row="1"
                BackgroundColor="#202124"
                Stroke="Transparent"
                Padding="10"
                Margin="10,8,10,0"
                IsVisible="{Binding IsTrackListVisible}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="6">
                <Label Text="Доріжки партитури"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#8A2BE2"
                       Margin="6,2,0,4" />
                <CollectionView ItemsSource="{Binding Tracks}"
                                MaximumHeightRequest="220"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="svc:TrackInfo">
                            <Grid Padding="10,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={x:Reference PlayerRoot}, Path=BindingContext.SelectTrackCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                                <mi:MauiIcon Grid.Column="0"
                                             Icon="{mi:Material MusicNote}"
                                             IconColor="#8A2BE2"
                                             IconSize="20"
                                             VerticalOptions="Center" />

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding DisplayName}" TextColor="White" FontSize="15" FontAttributes="Bold" />
                                    <Label Text="{Binding Details}" TextColor="#808080" FontSize="12" />
                                </VerticalStackLayout>

                                <mi:MauiIcon Grid.Column="2"
                                             Icon="{mi:Material CheckCircle}"
                                             IconColor="LimeGreen"
                                             IconSize="20"
                                             VerticalOptions="Center"
                                             IsVisible="{Binding HasNotes}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <!-- Табулатура у WebView, обгорнута фідбек-рамкою -->
        <Border Grid.Row="2"
                x:Name="FeedbackBorder"
                Stroke="{Binding FeedbackColor}"
                StrokeThickness="3"
                BackgroundColor="#121212"
                Margin="10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <Grid>
                <WebView x:Name="TabWebView"
                         Navigating="TabWebView_Navigating" />

                <VerticalStackLayout IsVisible="{Binding IsBusy}"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="10">
                    <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#8A2BE2" />
                    <Label Text="Завантаження табулатури…" TextColor="#808080" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Start"
                                     Spacing="8"
                                     Margin="20">
                    <mi:MauiIcon Icon="{mi:Material Info}" IconColor="#FF6B6B" IconSize="28" HorizontalOptions="Center" />
                    <Label Text="{Binding StatusMessage}"
                           TextColor="#FF6B6B"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Плашка живого фідбеку мікрофона -->
                <Border IsVisible="{Binding IsNoteCheckOn}"
                        BackgroundColor="#DD1A1A1A"
                        Stroke="{Binding MicStatusColor}"
                        StrokeThickness="2"
                        Padding="14,8"
                        Margin="0,14,14,0"
                        HorizontalOptions="End"
                        VerticalOptions="Start">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <mi:MauiIcon Icon="{mi:Material Mic}" IconColor="{Binding MicStatusColor}" IconSize="22" VerticalOptions="Center" />
                        <Label Text="{Binding MicNoteText}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"
                               WidthRequest="44"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding MicStatusText}"
                               FontSize="13"
                               TextColor="{Binding MicStatusColor}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Border>

        <!-- Панель керування -->
        <Border Grid.Row="3"
                BackgroundColor="#202124"
                Stroke="Transparent"
                Padding="14"
                Margin="10,0,10,10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="10">

                <!-- Таймлайн -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Slider Grid.Column="0"
                            x:Name="TimelineSlider"
                            Minimum="0"
                            Maximum="{Binding TimelineMax}"
                            Value="{Binding TimelineValue}"
                            DragStarted="Timeline_DragStarted"
                            DragCompleted="Timeline_DragCompleted"
                            MinimumTrackColor="#8A2BE2"
                            MaximumTrackColor="#404040"
                            ThumbColor="#8A2BE2" />
                    <Label Grid.Column="1"
                           Text="{Binding TimeLabel}"
                           TextColor="#B0B0B0"
                           FontSize="12"
                           VerticalOptions="Center" />
                </Grid>

                <!-- BPM -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <mi:MauiIcon Grid.Column="0" Icon="{mi:Material Speed}" IconColor="#B0B0B0" IconSize="20" VerticalOptions="Center" />
                    <Slider Grid.Column="1"
                            Minimum="{Binding BpmMin}"
                            Maximum="{Binding BpmMax}"
                            Value="{Binding BpmValue}"
                            MinimumTrackColor="#8A2BE2"
                            MaximumTrackColor="#404040"
                            ThumbColor="#8A2BE2" />
                    <Label Grid.Column="2" Text="{Binding BpmLabel}" TextColor="White" FontSize="13"
                           WidthRequest="70" VerticalOptions="Center" />
                </Grid>

                <!-- Кнопки -->
                <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8">
                    <Border Grid.Column="0" BackgroundColor="#8A2BE2" HeightRequest="50" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PlayPauseCommand}" />
                        </Border.GestureRecognizers>
                        <mi:MauiIcon Icon="{Binding IsPlaying, Converter={StaticResource PlayPauseIconConverter}}"
                                     IconColor="White" IconSize="26"
                                     HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="#333333" HeightRequest="50" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding StopCommand}" />
                        </Border.GestureRecognizers>
                        <mi:MauiIcon Icon="{mi:Material Stop}" IconColor="White" IconSize="24"
                                     HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <Border Grid.Column="2"
                            BackgroundColor="{Binding IsMetronomeOn, Converter={StaticResource BoolToToggleColorConverter}}"
                            HeightRequest="50" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleMetronomeCommand}" />
                        </Border.GestureRecognizers>
                        <mi:MauiIcon Icon="{mi:Material Timer}" IconColor="White" IconSize="24"
                                     HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <Border Grid.Column="3"
                            BackgroundColor="{Binding IsSynthMuted, Converter={StaticResource BoolToMuteColorConverter}}"
                            HeightRequest="50" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSynthCommand}" />
                        </Border.GestureRecognizers>
                        <mi:MauiIcon Icon="{Binding IsSynthMuted, Converter={StaticResource MuteIconConverter}}"
                                     IconColor="White" IconSize="24"
                                     HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <Border Grid.Column="4"
                            BackgroundColor="{Binding IsNoteCheckOn, Converter={StaticResource BoolToToggleColorConverter}}"
                            HeightRequest="50" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleNoteCheckCommand}" />
                        </Border.GestureRecognizers>
                        <mi:MauiIcon Icon="{mi:Material Mic}" IconColor="White" IconSize="24"
                                     HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>

                <Button Text="Назад до бібліотеки"
                        Command="{Binding BackCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#808080"
                        FontSize="13"
                        HeightRequest="36" />

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
