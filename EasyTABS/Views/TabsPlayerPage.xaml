<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyTABS.ViewModels"
             x:Class="EasyTABS.Views.TabsPlayerPage"
             x:Name="PlayerRoot"
             x:DataType="vm:TabsPlayerViewModel"
             Title="{Binding Title}"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:TabsPlayerViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Шапка: обкладинка + назва + вибір доріжки -->
        <Border Grid.Row="0"
                BackgroundColor="#202124"
                Stroke="Transparent"
                Padding="16"
                Margin="10,10,10,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                <Border Grid.Column="0"
                        WidthRequest="56" HeightRequest="56"
                        Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Image Source="{Binding AlbumCoverData, Converter={StaticResource BytesToImageConverter}}"
                           Aspect="AspectFill" />
                </Border>

                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" TextColor="White" />
                    <Label Text="{Binding ArtistName}" FontSize="13" TextColor="#B0B0B0" />
                </VerticalStackLayout>

                <Picker Grid.Column="2"
                        Title="Доріжка"
                        ItemsSource="{Binding Tracks}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedTrack}"
                        TextColor="White"
                        TitleColor="#8A2BE2"
                        WidthRequest="150" />
            </Grid>
        </Border>

        <!-- Табулатура у WebView, обгорнута фідбек-рамкою -->
        <Border Grid.Row="1"
                x:Name="FeedbackBorder"
                Stroke="{Binding FeedbackColor}"
                StrokeThickness="3"
                BackgroundColor="#121212"
                Margin="10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <Grid>
                <WebView x:Name="TabWebView"
                         Navigating="TabWebView_Navigating" />

                <VerticalStackLayout IsVisible="{Binding IsBusy}"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="10">
                    <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#8A2BE2" />
                    <Label Text="Завантаження…" TextColor="#808080" />
                </VerticalStackLayout>

                <Label Text="{Binding StatusMessage}"
                       IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
                       TextColor="#FF6B6B"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"
                       Margin="20"
                       HorizontalTextAlignment="Center" />
            </Grid>
        </Border>

        <!-- Панель керування -->
        <Border Grid.Row="2"
                BackgroundColor="#202124"
                Stroke="Transparent"
                Padding="14"
                Margin="10,0,10,10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="10">

                <!-- Таймлайн -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Slider Grid.Column="0"
                            x:Name="TimelineSlider"
                            Minimum="0"
                            Maximum="{Binding TimelineMax}"
                            Value="{Binding TimelineValue}"
                            DragStarted="Timeline_DragStarted"
                            DragCompleted="Timeline_DragCompleted"
                            MinimumTrackColor="#8A2BE2"
                            MaximumTrackColor="#404040"
                            ThumbColor="#8A2BE2" />
                    <Label Grid.Column="1"
                           Text="{Binding TimeLabel}"
                           TextColor="#B0B0B0"
                           FontSize="12"
                           VerticalOptions="Center" />
                </Grid>

                <!-- BPM -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Label Grid.Column="0" Text="Темп" TextColor="#B0B0B0" FontSize="13" VerticalOptions="Center" />
                    <Slider Grid.Column="1"
                            Minimum="{Binding BpmMin}"
                            Maximum="{Binding BpmMax}"
                            Value="{Binding BpmValue}"
                            MinimumTrackColor="#8A2BE2"
                            MaximumTrackColor="#404040"
                            ThumbColor="#8A2BE2" />
                    <Label Grid.Column="2" Text="{Binding BpmLabel}" TextColor="White" FontSize="13"
                           WidthRequest="70" VerticalOptions="Center" />
                </Grid>

                <!-- Кнопки -->
                <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="{Binding IsPlaying, Converter={StaticResource PlayPauseGlyphConverter}}"
                            FontFamily="MaterialSymbols"
                            FontSize="24"
                            Command="{Binding PlayPauseCommand}"
                            BackgroundColor="#8A2BE2" TextColor="White"
                            HeightRequest="50" CornerRadius="10" Padding="0" />
                    <Button Grid.Column="1"
                            Text="&#xe047;"
                            FontFamily="MaterialSymbols"
                            FontSize="22"
                            Command="{Binding StopCommand}"
                            BackgroundColor="#333333" TextColor="White"
                            HeightRequest="50" CornerRadius="10" Padding="0" />
                    <Button Grid.Column="2"
                            Text="&#xe1b8;"
                            FontFamily="MaterialSymbols"
                            FontSize="22"
                            Command="{Binding ToggleMetronomeCommand}"
                            BackgroundColor="{Binding IsMetronomeOn, Converter={StaticResource BoolToToggleColorConverter}}"
                            TextColor="White"
                            HeightRequest="50" CornerRadius="10" Padding="0" />
                    <Button Grid.Column="3"
                            Text="&#xe050;"
                            FontFamily="MaterialSymbols"
                            FontSize="22"
                            Command="{Binding ToggleSynthCommand}"
                            BackgroundColor="{Binding IsSynthMuted, Converter={StaticResource BoolToMuteColorConverter}}"
                            TextColor="White"
                            HeightRequest="50" CornerRadius="10" Padding="0" />
                    <Button Grid.Column="4"
                            Text="&#xe029;"
                            FontFamily="MaterialSymbols"
                            FontSize="22"
                            Command="{Binding ToggleNoteCheckCommand}"
                            BackgroundColor="{Binding IsNoteCheckOn, Converter={StaticResource BoolToToggleColorConverter}}"
                            TextColor="White"
                            HeightRequest="50" CornerRadius="10" Padding="0" />
                </Grid>

                <Button Text="Назад до бібліотеки"
                        Command="{Binding BackCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#808080"
                        FontSize="13"
                        HeightRequest="36" />

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
