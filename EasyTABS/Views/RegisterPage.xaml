<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyTABS.ViewModels"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="EasyTABS.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:RegisterViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#1E1E24" Offset="0" />
                <GradientStop Color="#121212" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <Border Stroke="Transparent"
                    BackgroundColor="#202124"
                    Padding="28"
                    Margin="24"
                    VerticalOptions="Center"
                    MaximumWidthRequest="460"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <mi:MauiIcon Icon="{mi:Material PersonAdd}"
                                 IconSize="60"
                                 IconColor="#8A2BE2"
                                 HorizontalOptions="Center"
                                 Margin="0,0,0,10" />

                    <Label Text="Створити акаунт"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />

                    <Label Text="Заповніть дані для реєстрації"
                           FontSize="14"
                           TextColor="#B0B0B0"
                           HorizontalOptions="Center"
                           Margin="0,5,0,28" />

                    <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,15">
                        <Grid ColumnDefinitions="Auto,*">
                            <mi:MauiIcon Grid.Column="0" Icon="{mi:Material Person}" IconColor="#808080" IconSize="22" Margin="15,0,0,0" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Margin="10,0,15,0"
                                   Placeholder="Придумайте нікнейм"
                                   Text="{Binding Nickname}"
                                   TextColor="White" PlaceholderColor="#808080"
                                   BackgroundColor="Transparent" FontSize="15" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,15">
                        <Grid ColumnDefinitions="Auto,*">
                            <mi:MauiIcon Grid.Column="0" Icon="{mi:Material Email}" IconColor="#808080" IconSize="22" Margin="15,0,0,0" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Margin="10,0,15,0"
                                   Placeholder="Електронна пошта"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   TextColor="White" PlaceholderColor="#808080"
                                   BackgroundColor="Transparent" FontSize="15" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,15">
                        <Grid ColumnDefinitions="Auto,*">
                            <mi:MauiIcon Grid.Column="0" Icon="{mi:Material Lock}" IconColor="#808080" IconSize="22" Margin="15,0,0,0" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Margin="10,0,15,0"
                                   Placeholder="Придумайте пароль"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   TextColor="White" PlaceholderColor="#808080"
                                   BackgroundColor="Transparent" FontSize="15" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,15">
                        <Grid ColumnDefinitions="Auto,*">
                            <mi:MauiIcon Grid.Column="0" Icon="{mi:Material LockReset}" IconColor="#808080" IconSize="22" Margin="15,0,0,0" VerticalOptions="Center" />
                            <Entry Grid.Column="1" Margin="10,0,15,0"
                                   Placeholder="Підтвердіть пароль"
                                   Text="{Binding ConfirmPassword}"
                                   IsPassword="True"
                                   TextColor="White" PlaceholderColor="#808080"
                                   BackgroundColor="Transparent" FontSize="15" />
                        </Grid>
                    </Border>

                    <HorizontalStackLayout Margin="4,5,0,20" Spacing="8">
                        <CheckBox IsChecked="{Binding AgreedToTerms}"
                                  Color="#8A2BE2"
                                  VerticalOptions="Center" />
                        <Label Text="Я згоден з умовами використання"
                               TextColor="#D0D0D0"
                               FontSize="14"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#FF6B6B"
                           FontSize="13"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                           Margin="0,0,0,12" />

                    <Border BackgroundColor="#8A2BE2" HeightRequest="55" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding RegisterCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                            <mi:MauiIcon Icon="{mi:Material HowToReg}" IconColor="White" IconSize="24" />
                            <Label Text="ЗАРЕЄСТРУВАТИСЯ" TextColor="White" FontSize="17" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <HorizontalStackLayout HorizontalOptions="Center" Margin="0,24,0,0" Spacing="4">
                        <Label Text="Вже маєте акаунт?"
                               TextColor="#808080"
                               VerticalOptions="Center" />
                        <Button Text="Увійти"
                                Command="{Binding GoToLoginCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#8A2BE2"
                                FontAttributes="Bold"
                                FontSize="14"
                                Padding="4,0" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>
