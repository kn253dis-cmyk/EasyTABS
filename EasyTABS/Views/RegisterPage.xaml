<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyTABS.ViewModels"
             x:Class="EasyTABS.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:RegisterViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#1E1E24" Offset="0" />
                <GradientStop Color="#121212" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView>
            <Border Stroke="Transparent"
                    BackgroundColor="#202124"
                    Padding="28"
                    Margin="24"
                    VerticalOptions="Center"
                    MaximumWidthRequest="460"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <Label Text="&#xe7fe;"
                           FontFamily="MaterialSymbols"
                           FontSize="60"
                           TextColor="#8A2BE2"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10" />

                    <Label Text="Створити акаунт"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />

                    <Label Text="Заповніть дані для реєстрації"
                           FontSize="14"
                           TextColor="#B0B0B0"
                           HorizontalOptions="Center"
                           Margin="0,5,0,28" />

                    <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,15">
                        <Entry Placeholder="Придумайте нікнейм"
                               Text="{Binding Nickname}"
                               TextColor="White"
                               PlaceholderColor="#808080"
                               BackgroundColor="Transparent"
                               FontSize="15" />
                    </Border>

                    <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,15">
                        <Entry Placeholder="Електронна пошта"
                               Text="{Binding Email}"
                               Keyboard="Email"
                               TextColor="White"
                               PlaceholderColor="#808080"
                               BackgroundColor="Transparent"
                               FontSize="15" />
                    </Border>

                    <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,15">
                        <Entry Placeholder="Придумайте пароль"
                               Text="{Binding Password}"
                               IsPassword="True"
                               TextColor="White"
                               PlaceholderColor="#808080"
                               BackgroundColor="Transparent"
                               FontSize="15" />
                    </Border>

                    <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,15">
                        <Entry Placeholder="Підтвердіть пароль"
                               Text="{Binding ConfirmPassword}"
                               IsPassword="True"
                               TextColor="White"
                               PlaceholderColor="#808080"
                               BackgroundColor="Transparent"
                               FontSize="15" />
                    </Border>

                    <HorizontalStackLayout Margin="4,5,0,20" Spacing="8">
                        <CheckBox IsChecked="{Binding AgreedToTerms}"
                                  Color="#8A2BE2"
                                  VerticalOptions="Center" />
                        <Label Text="Я згоден з умовами використання"
                               TextColor="#D0D0D0"
                               FontSize="14"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#FF6B6B"
                           FontSize="13"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                           Margin="0,0,0,12" />

                    <Button Text="ЗАРЕЄСТРУВАТИСЯ"
                            Command="{Binding RegisterCommand}"
                            HeightRequest="55"
                            FontSize="18"
                            FontAttributes="Bold"
                            BackgroundColor="#8A2BE2"
                            TextColor="White"
                            CornerRadius="12" />

                    <HorizontalStackLayout HorizontalOptions="Center" Margin="0,24,0,0" Spacing="4">
                        <Label Text="Вже маєте акаунт?"
                               TextColor="#808080"
                               VerticalOptions="Center" />
                        <Button Text="Увійти"
                                Command="{Binding GoToLoginCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#8A2BE2"
                                FontAttributes="Bold"
                                FontSize="14"
                                Padding="4,0" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>
