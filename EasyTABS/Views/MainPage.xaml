<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyTABS.ViewModels"
             xmlns:models="clr-namespace:EasyTABS.Models"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="EasyTABS.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="EasyTABS"
             BackgroundColor="#121212">

    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#1E1E24" Offset="0" />
                <GradientStop Color="#121212" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Stroke="Transparent"
                BackgroundColor="#202124"
                Padding="20"
                Margin="16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

                <!-- Рядок пошуку -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,0,0,16">
                    <Border Grid.Column="0" Style="{StaticResource FieldBorder}">
                        <Grid ColumnDefinitions="Auto,*">
                            <mi:MauiIcon Grid.Column="0" Icon="{mi:Material Search}" IconColor="#808080" IconSize="22" Margin="15,0,0,0" VerticalOptions="Center" />
                            <Entry Grid.Column="1"
                                   Margin="10,0,15,0"
                                   Placeholder="Знайти пісню..."
                                   Text="{Binding SearchText}"
                                   TextColor="White"
                                   PlaceholderColor="#808080"
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   HeightRequest="50" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="#8A2BE2" WidthRequest="50" HeightRequest="50" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SearchCommand}" />
                        </Border.GestureRecognizers>
                        <mi:MauiIcon Icon="{mi:Material Search}" IconColor="White" IconSize="24"
                                     HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- Список пісень -->
                <Grid Grid.Row="1" RowDefinitions="Auto,*">
                    <HorizontalStackLayout Grid.Row="0" Spacing="8" Margin="4,0,0,10">
                        <mi:MauiIcon Icon="{mi:Material LibraryMusic}" IconColor="#8A2BE2" IconSize="22" VerticalOptions="Center" />
                        <Label Text="Усі пісні"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding Songs}"
                                    SelectionMode="Single"
                                    SelectedItem="{Binding SelectedSong}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Song">
                                <Border BackgroundColor="#2A2D34"
                                        Stroke="Transparent"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                                        <Border Grid.Column="0"
                                                WidthRequest="55"
                                                HeightRequest="55"
                                                Stroke="Transparent">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8" />
                                            </Border.StrokeShape>
                                            <Image Source="{Binding AlbumCoverData, 
                                                Converter={StaticResource BytesToImageConverter}}"
                                                   Aspect="AspectFill" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding Title}"
                                                   FontAttributes="Bold"
                                                   FontSize="16"
                                                   TextColor="White" />
                                            <Label Text="{Binding Artist.Name}"
                                                   FontSize="13"
                                                   TextColor="#B0B0B0"
                                                   Margin="0,4,0,0" />
                                        </VerticalStackLayout>

                                        <mi:MauiIcon Grid.Column="2"
                                                     Icon="{mi:Material ChevronRight}"
                                                     IconColor="#606060"
                                                     IconSize="24"
                                                     VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Спливаючі підказки поверх списку -->
                    <Border Grid.Row="1"
                            BackgroundColor="#2A2D34"
                            Stroke="#404040"
                            Padding="0"
                            Margin="0,4,0,0"
                            VerticalOptions="Start"
                            MaximumHeightRequest="260"
                            IsVisible="{Binding IsSuggestionsVisible}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <CollectionView ItemsSource="{Binding Suggestions}"
                                        SelectionMode="Single"
                                        SelectedItem="{Binding SelectedSong}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Song">
                                    <Grid Padding="12,8" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <mi:MauiIcon Grid.Column="0" Icon="{mi:Material MusicNote}" IconColor="#8A2BE2" IconSize="20" VerticalOptions="Center" />
                                        <VerticalStackLayout Grid.Column="1">
                                            <Label Text="{Binding Title}"
                                                   FontAttributes="Bold"
                                                   FontSize="15"
                                                   TextColor="White" />
                                            <Label Text="{Binding Artist.Name}"
                                                   FontSize="13"
                                                   TextColor="#B0B0B0"
                                                   Margin="0,2,0,0" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                </Grid>

                <!-- Нижні кнопки -->
                <Grid Grid.Row="2" ColumnDefinitions="*,20,*" Margin="0,16,0,0">
                    <Border Grid.Column="0" BackgroundColor="#333333" HeightRequest="55" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenTunerCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                            <mi:MauiIcon Icon="{mi:Material Tune}" IconColor="White" IconSize="22" />
                            <Label Text="Тюнер" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border Grid.Column="2" BackgroundColor="#8A2BE2" HeightRequest="55" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AddSongCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                            <mi:MauiIcon Icon="{mi:Material Add}" IconColor="White" IconSize="24" />
                            <Label Text="Додати пісню" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</ContentPage>
