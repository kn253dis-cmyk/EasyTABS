<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:EasyTABS"
             xmlns:conv="clr-namespace:EasyTABS.Converters"
             x:Class="EasyTABS.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Конвертери -->
            <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <conv:BoolToNoteColorConverter x:Key="BoolToNoteColorConverter" />

            <!-- Обведена рамка для полів вводу (аналог MaterialDesignOutlinedTextBox) -->
            <Style x:Key="FieldBorder" TargetType="Border">
                <Setter Property="Stroke" Value="#404040" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="BackgroundColor" Value="#121212" />
                <Setter Property="Padding" Value="12,2" />
                <Setter Property="StrokeShape">
                    <RoundRectangle CornerRadius="10" />
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
